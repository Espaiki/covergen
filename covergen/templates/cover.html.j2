<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>{{ subject_name }} — {{ student_name }}</title>

<style>
/* ============================================================
   FONTS
   ============================================================ */
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap');

/* ============================================================
   PHASE 2 — CSS Custom Properties (palette from LayoutContext)
   ============================================================ */
:root {
  --color-primary:   {{ palette_primary }};
  --color-accent:    {{ palette_accent }};
  --color-panel-bg:  {{ palette_panel_bg }};
  --color-outline:   {{ palette_outline }};
}

/* ============================================================
   CSS PAGED MEDIA
   ============================================================ */
@page {
  size: {{ width_cm }}cm {{ height_cm }}cm;
  margin: 0;
  marks: none;
  bleed: 0;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  width:  {{ width_cm }}cm;
  height: {{ height_cm }}cm;
}

/* PHASE 4 — body is the absolute-position anchor for .deco elements */
body {
  position: relative;
  overflow: hidden;
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
  font-family: 'Nunito', 'Trebuchet MS', Arial, sans-serif;

  {% if background_image_b64 %}
  background-image: url('data:image/png;base64,{{ background_image_b64 }}');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-position: center;
  {% else %}
  background: linear-gradient(135deg,
    #ff9a9e 0%, #fecfef 28%, #a18cd1 62%, #fbc2eb 100%);
  {% endif %}
}

/* ============================================================
   PHASE 4 — Corner decoration slots
   ============================================================ */
.deco {
  position: absolute;
  width:  4cm;
  height: 4cm;
  color: var(--color-primary);   /* SVGs inherit via currentColor */
  opacity: 0.85;
  pointer-events: none;
}
.deco svg { width: 100%; height: 100%; display: block; }

.deco--top-left     { top: 0;    left: 0; }
.deco--top-right    { top: 0;    right: 0;  transform: scaleX(-1); }
.deco--bottom-left  { bottom: 0; left: 0;   transform: scaleY(-1); }
.deco--bottom-right { bottom: 0; right: 0;  transform: scale(-1,-1); }

/* ============================================================
   PHASE 2 — Text-outline utilities (palette-aware shadows)
   ============================================================ */
.outline-strong {
  text-shadow:
     2px  2px 0 var(--color-outline),
    -2px -2px 0 var(--color-outline),
     2px -2px 0 var(--color-outline),
    -2px  2px 0 var(--color-outline),
     0    2px 0 var(--color-outline),
     0   -2px 0 var(--color-outline),
     2px  0   0 var(--color-outline),
    -2px  0   0 var(--color-outline),
     0    0   6px var(--color-outline);
  -webkit-text-stroke: 1.5px rgba(0,0,0,0.75);
}

.outline-medium {
  text-shadow:
     1px  1px 0 var(--color-outline),
    -1px -1px 0 var(--color-outline),
     1px -1px 0 var(--color-outline),
    -1px  1px 0 var(--color-outline),
     0    1px 0 var(--color-outline),
     0   -1px 0 var(--color-outline),
     1px  0   0 var(--color-outline),
    -1px  0   0 var(--color-outline);
  -webkit-text-stroke: 1px rgba(0,0,0,0.70);
}

/* ============================================================
   PHASE 1 — Cover shell (safe-margin from context)
   ============================================================ */
.cover {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: {{ safe_margin_cm }}cm 1.5cm;
  font-size: 2.4vh;
}

.card {
  background: transparent;
  border: none;
  padding: 0;
}

/* ============================================================
   HEADER — Institution name
   ============================================================ */
.cover__header {
  text-align: center;
}

.institution {
  font-family: 'Nunito', 'Trebuchet MS', sans-serif;
  font-weight: 900;
  font-size: 1.1em;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-primary);
  line-height: 1.35;
  text-align: center;
  max-width: 85%;
  margin: 0 auto;
}

/* ============================================================
   MAIN — Subject (dominant element)
   ============================================================ */
.cover__main {
  text-align: center;
}

.subject {
  font-family: 'Fredoka One', 'Arial Rounded MT Bold', 'Trebuchet MS', Arial, sans-serif;
  font-weight: 400;
  font-size: 3.5em;
  line-height: 1.05;
  letter-spacing: -0.01em;
  color: var(--color-primary);
}

/* ============================================================
   FOOTER — metadata block + year
   ============================================================ */
.cover__footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.8em;
}

/* PHASE 3 — CSS table layout: labels right-align, values left-align,
   whole block auto-centered by margin: 0 auto on display:table. */
.meta {
  display: table;
  margin: 0 auto;
  border-collapse: separate;
  border-spacing: 1.2em 0.5em;
  background: var(--color-panel-bg);
  padding: 0.6em 1em;
  border-radius: 14px;
}

.meta__row {
  display: table-row;
}

.meta__label {
  display: table-cell;
  text-align: right;
  vertical-align: baseline;
  font-family: 'Nunito', sans-serif;
  font-weight: 900;
  font-size: 0.85em;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-accent);
  white-space: nowrap;
}

.meta__value {
  display: table-cell;
  text-align: left;
  vertical-align: baseline;
  font-family: 'Nunito', sans-serif;
  font-weight: 700;
  color: var(--color-primary);
  white-space: nowrap;
}

/* Year — centered below the meta table */
.year {
  font-family: 'Nunito', sans-serif;
  font-weight: 900;
  font-size: 1.8em;
  color: var(--color-primary);
  letter-spacing: 0.28em;
  text-align: center;
  width: 100%;
}
</style>
</head>

<body>
{# PHASE 4 — SVG corner ornaments, injected before the cover shell #}
{% if decorations %}
  {% for slot in decorations %}
    <div class="deco deco--{{ slot.position }}">{{ slot.svg | safe }}</div>
  {% endfor %}
{% endif %}

<div class="cover">

  <!-- ── HEADER ── -->
  <header class="cover__header">
    <div class="card">
      <div class="institution outline-strong">{{ institution_name }}</div>
    </div>
  </header>

  <!-- ── MAIN ── -->
  <main class="cover__main">
    <div class="card">
      <h1 class="subject outline-strong">{{ subject_name }}</h1>
    </div>
  </main>

  <!-- ── FOOTER — CSS-table meta block + year ── -->
  <footer class="cover__footer">
    <div class="card">
      <div class="meta">
        <div class="meta__row">
          <span class="meta__label outline-medium">Estudiante</span>
          <span class="meta__value outline-medium">{{ student_name }}</span>
        </div>
        <div class="meta__row">
          <span class="meta__label outline-medium">Docente</span>
          <span class="meta__value outline-medium">{{ teacher_name }}</span>
        </div>
        <div class="meta__row">
          <span class="meta__label outline-medium">{{ course_label | upper }}</span>
          <span class="meta__value outline-medium">{{ grade_course }}</span>
        </div>
      </div>
    </div>
    <div class="year outline-strong">{{ school_year }}</div>
  </footer>

</div>
</body>
</html>
