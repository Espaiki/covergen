<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>{{ subject_name }} — {{ student_name }}</title>

<style>
/* ============================================================
   FONTS
   ============================================================ */
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap');

/* ============================================================
   CSS PAGED MEDIA
   ============================================================ */
@page {
  size: {{ width_cm }}cm {{ height_cm }}cm;
  margin: 0;
  marks: none;
  bleed: 0;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  width:  {{ width_cm }}cm;
  height: {{ height_cm }}cm;
}

body {
  overflow: hidden;
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
  font-family: 'Nunito', 'Trebuchet MS', Arial, sans-serif;

  {% if background_image_b64 %}
  background-image: url('data:image/png;base64,{{ background_image_b64 }}');
  background-size: 100% 100%;
  background-repeat: no-repeat;
  background-position: center;
  {% else %}
  background: linear-gradient(135deg,
    #ff9a9e 0%, #fecfef 28%, #a18cd1 62%, #fbc2eb 100%);
  {% endif %}
}

/* ============================================================
   TEXT-OUTLINE UTILITIES
   8-directional text-shadow funciona en WeasyPrint/Cairo.
   -webkit-text-stroke mejora el preview en Chromium (Streamlit).
   ============================================================ */
.outline-strong {
  text-shadow:
     2px  2px 0 rgba(0,0,0,0.90),
    -2px -2px 0 rgba(0,0,0,0.90),
     2px -2px 0 rgba(0,0,0,0.90),
    -2px  2px 0 rgba(0,0,0,0.90),
     0    2px 0 rgba(0,0,0,0.90),
     0   -2px 0 rgba(0,0,0,0.90),
     2px  0   0 rgba(0,0,0,0.90),
    -2px  0   0 rgba(0,0,0,0.90),
     0    0   6px rgba(0,0,0,0.50);
  -webkit-text-stroke: 1.5px rgba(0,0,0,0.75);
}

.outline-medium {
  text-shadow:
     1px  1px 0 rgba(0,0,0,0.85),
    -1px -1px 0 rgba(0,0,0,0.85),
     1px -1px 0 rgba(0,0,0,0.85),
    -1px  1px 0 rgba(0,0,0,0.85),
     0    1px 0 rgba(0,0,0,0.85),
     0   -1px 0 rgba(0,0,0,0.85),
     1px  0   0 rgba(0,0,0,0.85),
    -1px  0   0 rgba(0,0,0,0.85);
  -webkit-text-stroke: 1px rgba(0,0,0,0.70);
}

/* ============================================================
   COVER SHELL — flex column, espacio distribuido
   padding: top y bottom para clearance del marco de imagen.
   FIX: se elimina el padding-top agresivo; la institución
   se posiciona de forma natural en el primer flex-item.
   ============================================================ */
.cover {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 5vh 4vw 5vh;
  font-size: 2.4vh;
}

.card {
  background: transparent;
  border: none;
  padding: 0;
}

/* ============================================================
   HEADER — Institución
   FIX Bug 1: sin margin-top agresivo; la institución aparece
   en la parte superior natural del flujo flex.
   ============================================================ */
.cover__header {
  text-align: center;
}

.institution {
  font-family: 'Nunito', 'Trebuchet MS', sans-serif;
  font-weight: 900;
  font-size: 1.1em;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #ffffff;
  line-height: 1.35;
  text-align: center;
  max-width: 85%;
  margin: 0 auto;
}

/* ============================================================
   MAIN — Materia (elemento dominante)
   ============================================================ */
.cover__main {
  text-align: center;
}

.subject {
  font-family: 'Fredoka One', 'Arial Rounded MT Bold', 'Trebuchet MS', Arial, sans-serif;
  font-weight: 400;
  font-size: 3.5em;
  line-height: 1.05;
  letter-spacing: -0.01em;
  color: #ffffff;
}

/* ============================================================
   FOOTER — bloque de datos + año
   FIX Bug 2: footer centra horizontalmente el bloque .meta.
   El bloque .meta tiene ancho fijo (65%) y texto left-aligned
   dentro — efecto "bloque centrado, texto a la izquierda".
   ============================================================ */
.cover__footer {
  display: flex;
  flex-direction: column;
  align-items: center;   /* centra el bloque .meta en la página */
  gap: 0.8em;
}

.meta {
  width: 65%;            /* ancho definido → el auto-margin lo centra */
  display: flex;
  flex-direction: column;
  gap: 0.6em;
}

.meta__row {
  display: flex;
  align-items: baseline;
  gap: 0.8em;
  font-size: 1.25em;
  text-align: left;
}

.meta__label {
  font-family: 'Nunito', sans-serif;
  font-weight: 900;
  font-size: 0.7em;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #ffffff;
  min-width: 6em;
  flex-shrink: 0;
}

.meta__value {
  font-family: 'Nunito', sans-serif;
  font-weight: 700;
  color: #ffffff;
}

/* Año lectivo — centrado, bajo el bloque de datos */
.year {
  font-family: 'Nunito', sans-serif;
  font-weight: 900;
  font-size: 1.8em;
  color: #ffffff;
  letter-spacing: 0.28em;
  text-align: center;
  width: 100%;
}
</style>
</head>

<body>
<div class="cover">

  <!-- ── HEADER — institución en la parte superior ── -->
  <header class="cover__header">
    <div class="card">
      <div class="institution outline-strong">{{ institution_name }}</div>
    </div>
  </header>

  <!-- ── MAIN — materia (elemento dominante) ── -->
  <main class="cover__main">
    <div class="card">
      <h1 class="subject outline-strong">{{ subject_name }}</h1>
    </div>
  </main>

  <!-- ── FOOTER — bloque de datos centrado + año ── -->
  <footer class="cover__footer">
    <div class="card">
      <div class="meta">
        <div class="meta__row">
          <span class="meta__label outline-medium">Estudiante</span>
          <span class="meta__value outline-medium">{{ student_name }}</span>
        </div>
        <div class="meta__row">
          <span class="meta__label outline-medium">Docente</span>
          <span class="meta__value outline-medium">{{ teacher_name }}</span>
        </div>
        <div class="meta__row">
          <span class="meta__label outline-medium">{{ course_label | upper }}</span>
          <span class="meta__value outline-medium">{{ grade_course }}</span>
        </div>
      </div>
    </div>
    <div class="year outline-strong">{{ school_year }}</div>
  </footer>

</div>
</body>
</html>
